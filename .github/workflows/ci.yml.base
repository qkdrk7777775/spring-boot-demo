name: CI
on: [push]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
      - uses: actions/checkout@v2
      - run: echo "Hello, DevOps!"

      - name: Set up JDK 17
      - uses: actions/setup-java@v2
        with:
          java-version: "17"
          distribution: "temurin"


